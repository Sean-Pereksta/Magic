+  try{
+    const frame = wctx.getImageData(0,0,work.width,work.height);
+    const data = frame.data, width=work.width, height=work.height;
+    const visited = new Uint8Array(width*height);
+    const queue = new Int32Array(width*height);
+    let head=0,tail=0;
+    const darkEdge = idx => {
+      const o=idx*4,r=data[o],g=data[o+1],b=data[o+2];
+      const max=Math.max(r,g,b),min=Math.min(r,g,b),lum=(r*3+g*4+b)/8;
