+    for(let x=0;x<width;x++){push(x);push((height-1)*width+x);}
+    for(let y=0;y<height;y++){push(y*width);push(y*width+width-1);}
+    while(head<tail){
+      const idx=queue[head++],x=idx%width,y=(idx/width)|0;
+      if(x>0)push(idx-1);if(x+1<width)push(idx+1);if(y>0)push(idx-width);if(y+1<height)push(idx+width);
+    }
+    for(let i=0;i<visited.length;i++) if(visited[i]) data[i*4+3]=0;
+    wctx.putImageData(frame,0,0);
+    let minX=width,minY=height,maxX=-1,maxY=-1;
+    for(let y=0;y<height;y++)for(let x=0;x<width;x++)if(data[(y*width+x)*4+3]>12){minX=Math.min(minX,x);minY=Math.min(minY,y);maxX=Math.max(maxX,x);maxY=Math.max(maxY,y);}
